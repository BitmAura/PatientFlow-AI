{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        { "type": "host", "value": "app.patientflow.ai" }
      ],
      "destination": "https://patientflow.ai/$1",
      "permanent": true
    }
  ],
  "crons": [
    { "path": "/api/cron/send-reminders", "schedule": "0 10 * * *" },
    { "path": "/api/cron/process-campaigns", "schedule": "0 11 * * *" },
    { "path": "/api/cron/leads", "schedule": "0 9 * * *" },
    { "path": "/api/cron/recalls", "schedule": "0 8 * * *" }
  ]
}
