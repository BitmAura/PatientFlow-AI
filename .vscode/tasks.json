{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "Ready in"
        }
      }
    },
    {
      "label": "npm: start",
      "type": "shell",
      "command": "npm run start",
      "isBackground": true
    }
  ]
}
